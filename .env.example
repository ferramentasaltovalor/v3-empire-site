# .env.example
# ================================================
# COPIE PARA .env E PREENCHA OS VALORES REAIS
# NUNCA COMMITE O ARQUIVO .env
# ================================================

# ================================================
# SUPABASE — Projeto: Empire site 3
# Dashboard: https://supabase.com/dashboard
# Encontrar em: Project Settings > API
# ================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=
SUPABASE_JWT_SECRET=

# ================================================
# OPENROUTER
# Dashboard: https://openrouter.ai/keys
# Modelos: https://openrouter.ai/models
# Documentação: ver docs/integracoes.md seção OpenRouter
# ================================================
# API Key (obrigatória) - começa com sk-or-v1-
OPENROUTER_API_KEY=

# Modelo padrão (opcional) - ver IDs em openrouter.ai/models
# Recomendados: anthropic/claude-sonnet-4, anthropic/claude-3.5-haiku
OPENROUTER_DEFAULT_MODEL=anthropic/claude-sonnet-4

# URL do site para rate limiting (obrigatório para produção)
OPENROUTER_HTTP_REFERER=https://empire.com.br

# Nome do app para tracking (obrigatório para produção)
OPENROUTER_X_TITLE=Empire Site

# ================================================
# SCRAPE CREATORS API
# ================================================
SCRAPE_CREATORS_API_KEY=

# ================================================
# URL DO SITE
# Desenvolvimento: http://localhost:3000
# Produção: https://www.empire.com.br (confirmar)
# ================================================
NEXT_PUBLIC_SITE_URL=

# ================================================
# SEGURANÇA
# ================================================
WEBHOOK_SIGNING_SECRET=
CRON_SECRET=

# ================================================
# SUPABASE STORAGE
# ================================================
NEXT_PUBLIC_SUPABASE_STORAGE_URL=

# ================================================
# ANALYTICS
# ================================================
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ================================================
# FEATURE FLAGS
# ================================================
NEXT_PUBLIC_ENABLE_AI_GENERATION=true
NEXT_PUBLIC_ENABLE_LANDING_PAGES=true
NEXT_PUBLIC_ENABLE_API_REST=true
